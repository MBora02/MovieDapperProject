@model List<MovieDapperProject.Models.MoviesModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">

    <a href="/Movies/EY" class="btn btn-primary mb-3">
        + Add Movie
    </a>

    <table class="table table-hover my-0">
        <thead>
            <tr>
                <th>Title</th>
                <th>Year</th>
                <th>Duration</th>
                <th>Genre</th>
                <th>Director</th>
                <th>Budget</th>
                <th>Revenue</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.ReleaseYear</td>
                    <td>@item.Duration</td>
                    <td>@item.GenreName</td>
                    <td>@item.DirectorName</td>
                    <td>@item.Budget</td>
                    <td>@item.Revenue</td>

                    <td class="text-end">
                        <a href="/Movies/EY/@item.Id" class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a href="/Movies/Delete/@item.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Delete this movie?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>