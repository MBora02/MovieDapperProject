@model List<MovieDapperProject.Models.DirectorsModel>

<div class="container mt-3">

    <a href="/Directors/EY" class="btn btn-primary mb-3">
        + Add Director
    </a>

    <table class="table table-hover my-0">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th class="d-none d-xl-table-cell">Birth Date</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FirstName</td>
                    <td>@item.LastName</td>
                    <td class="d-none d-xl-table-cell">
                        @(item.BirthDate?.ToString("dd/MM/yyyy"))
                    </td>

                    <td class="text-end">
                        <a href="/Directors/EY/@item.Id" class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a href="/Directors/Delete/@item.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Delete this director?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>