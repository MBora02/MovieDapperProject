@model MovieDapperProject.Models.DashboardModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <div class="row">

        <!-- TOTAL MOVIES -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Total Movies</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-primary">
                                <i data-feather="film"></i>
                            </div>
                        </div>
                    </div>

                    <h1 class="mt-1 mb-3">@Model.TotalMovies</h1>

                    <div class="mb-0">
                        <span class="text-muted">Movies in database</span>
                    </div>

                </div>
            </div>
        </div>

        <!-- TOTAL REVIEWS -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Total Reviews</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-success">
                                <i data-feather="star"></i>
                            </div>
                        </div>
                    </div>

                    <h1 class="mt-1 mb-3">@Model.TotalReviews</h1>

                    <div class="mb-0">
                        <span class="text-muted">User reviews</span>
                    </div>

                </div>
            </div>
        </div>

        <!-- TOTAL GENRES -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Total Genres</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-warning">
                                <i data-feather="tag"></i>
                            </div>
                        </div>
                    </div>

                    <h1 class="mt-1 mb-3">@Model.TotalGenres</h1>

                    <div class="mb-0">
                        <span class="text-muted">Categories</span>
                    </div>

                </div>
            </div>
        </div>

        <!-- BEST MOVIE -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Best Profit Movie</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-success">
                                <i data-feather="trending-up"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="mt-1 mb-3">@Model.BestMovieTitle</h3>

                    <div class="mb-0">
                        <span class="text-danger">
                            Profit: @Model.BestMovieProfit
                        </span>
                    </div>

                </div>
            </div>
        </div>

        <!-- BEST DIRECTOR -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Top Director</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-primary">
                                <i data-feather="user"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="mt-1 mb-3">@Model.BestDirectorName</h3>

                    <div class="mb-0">
                        <span class="text-muted">
                            Movies: @Model.BestDirectorMovieCount
                        </span>
                    </div>

                </div>
            </div>
        </div>

        <!-- BEST GENRE -->
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">

                    <div class="row">
                        <div class="col mt-0">
                            <h5 class="card-title">Most Popular Genre</h5>
                        </div>

                        <div class="col-auto">
                            <div class="stat text-warning">
                                <i data-feather="award"></i>
                            </div>
                        </div>
                    </div>

                    <h2 class="mt-1 mb-3">@Model.BestGenreName</h2>

                    <div class="mb-0">
                        <span class="text-muted">
                            Movies: @Model.BestGenreMovieCount
                        </span>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>