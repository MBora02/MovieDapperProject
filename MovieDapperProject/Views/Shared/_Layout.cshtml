@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>MovieDapper Admin</title>

    <link href="~/adminkit/static/css/app.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body>

    <div class="wrapper">

        <!-- SIDEBAR -->
        <nav id="sidebar" class="sidebar js-sidebar">
            <div class="sidebar-content js-simplebar">

                <a class="sidebar-brand" href="/Home/Index">
                    <span class="align-middle">MovieDapper Admin</span>
                </a>

                <ul class="sidebar-nav">

                    <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">
                        <a class="sidebar-link" href="/Home/Index">
                            Dashboard
                        </a>
                    </li>

                    <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Genres" ? "active" : "")">
                        <a class="sidebar-link" href="/Genres/Index">
                            Genres
                        </a>
                    </li>

                    <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Directors" ? "active" : "")">
                        <a class="sidebar-link" href="/Directors/Index">
                            Directors
                        </a>
                    </li>

                    <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Movies" ? "active" : "")">
                        <a class="sidebar-link" href="/Movies/Index">
                            Movies
                        </a>
                    </li>

                    <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Reviews" ? "active" : "")">
                        <a class="sidebar-link" href="/Reviews/Index">
                            Reviews
                        </a>
                    </li>

                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <li class="sidebar-item @(ViewContext.RouteData.Values["controller"].ToString() == "Users" ? "active" : "")">
                            <a class="sidebar-link" href="/Users/ChangePassword">
                                Change Password
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </nav>

        <!-- MAIN -->
        <div class="main">

            <!-- TOP BAR -->
            <nav class="navbar navbar-expand navbar-light navbar-bg">

                <a class="sidebar-toggle js-sidebar-toggle">
                    ☰
                </a>

                <div class="navbar-collapse collapse justify-content-end">

                    <ul class="navbar-nav">

                        <li class="nav-item me-3">

                            @if (Context.Session.GetString("UserName") != null)
                            {
                                <span class="text-dark me-2">
                                    Hello @Context.Session.GetString("UserName")
                                </span>

                                <a href="/Users/Logout" class="btn btn-danger btn-sm">
                                    Logout
                                </a>
                            }
                            else
                            {
                                <a href="/Users/Login" class="btn btn-primary btn-sm">
                                    Login
                                </a>
                            }

                        </li>

                    </ul>

                </div>

            </nav>

            <!-- CONTENT -->
            <main class="content">

                <div class="container-fluid p-0">

                    <div class="card">

                        <div class="card-body">
                            @RenderBody()
                        </div>

                    </div>

                </div>

            </main>

        </div>

    </div>

    <script src="~/adminkit/static/js/app.js"></script>

</body>
</html>