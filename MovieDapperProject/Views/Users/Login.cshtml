@model MovieDapperProject.Models.UsersModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link href="~/adminkit/static/css/app.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="row justify-content-center">
            <div class="col-md-4">

                <div class="card">

                    <div class="card-header text-center">
                        <h3>Login</h3>
                    </div>

                    <div class="card-body">

                        <form method="post">

                            <div class="mb-3">
                                <label>User Name</label>
                                <input asp-for="UserName" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label>Password</label>
                                <input asp-for="PasswordHash" type="password" class="form-control" />
                            </div>

                            <button class="btn btn-primary w-100">
                                Login
                            </button>

                            @if (ViewBag.Error != null)
                            {
                                <div class="text-danger mt-2">
                                    @ViewBag.Error
                                </div>
                            }

                        </form>

                        <hr />

                        <!-- REGISTER BUTTON -->
                        <div class="text-center">
                            <p>Don't have an account?</p>

                            <a href="/Users/Register" class="btn btn-outline-success w-100">
                                Create Account
                            </a>
                        </div>

                    </div>

                </div>

            </div>
        </div>

    </div>

</body>
</html>