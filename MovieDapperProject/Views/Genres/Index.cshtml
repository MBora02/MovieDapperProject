@model List<MovieDapperProject.Models.GenresModel>

<div class="container mt-3">

    <div class="mb-3">
        <a href="/Genres/EY" class="btn btn-primary">
            + Add Genre
        </a>
        <a href="/Genres/ExportToPdf" class="btn btn-danger ms-2">
            <i class="fa fa-file-pdf"></i> PDF Olarak İndir
        </a>
        <a href="/Genres/ExportToExcel" class="btn btn-success ms-2">
            <i class="fa fa-file-excel"></i> Excel Olarak İndir
        </a>
    </div>

    <table class="table table-hover my-0">
        <thead>
            <tr>
                <th>Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>

                    <td class="text-end">
                        <a href="/Genres/EY/@item.Id" class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a href="/Genres/Delete/@item.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Delete this genre?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>