@model MovieDapperProject.Models.GenresModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">

    <h3 class="mb-3">Genre Form</h3>

    <form method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Genre Name</label>
            <input type="text" class="form-control" asp-for="Name" />
        </div>

        <button type="submit" class="btn btn-success">
            Save
        </button>

        <a href="/Genres/Index" class="btn btn-secondary">
            Back
        </a>

    </form>

</div>